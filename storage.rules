rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Product images ────────────────────────────────────────────────────────
    // Path: products/{distributorId}/{filename}
    // Any authenticated user can read; only the owning distributor can write.
    match /products/{distributorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == distributorId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == distributorId;
    }

    // ── Distributor logos ─────────────────────────────────────────────────────
    // Path: distribuidoras/{distributorId}/logo/{filename}
    match /distribuidoras/{distributorId}/logo/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == distributorId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == distributorId;
    }

    // ── Commerce logos ────────────────────────────────────────────────────────
    // Path: comercios/{comercioId}/logo/{filename}
    match /comercios/{comercioId}/logo/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == comercioId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == comercioId;
    }
  }
}
